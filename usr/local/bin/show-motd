#!/usr/bin/env bash
# show-motd — display the welcome banner and the live network allowlist.
# Reads allowlist.conf from the workspace (always up to date with the repo),
# falling back to the image copy baked in at build time.

cat /etc/motd

ALLOWLIST="/workspaces/archive/.devcontainer/etc/squid/allowlist.conf"
[ -f "$ALLOWLIST" ] || ALLOWLIST="/etc/squid/allowlist.conf"

echo "  Network allowlist (outbound HTTPS via squid proxy):"
echo ""

current_desc=""
desc_shown=false

while IFS= read -r line; do
  if [[ -z "$line" ]]; then
    current_desc=""
    desc_shown=false
  elif [[ "$line" =~ ^#[[:space:]]*(.*) ]]; then
    # Use the first comment in a group as the human-readable description.
    [[ -z "$current_desc" ]] && current_desc="${BASH_REMATCH[1]}"
  elif [[ "$line" =~ ^\. ]]; then
    domain="${line#.}"
    if [[ -n "$current_desc" && "$desc_shown" == false ]]; then
      printf "    %-30s — %s\n" "$domain" "$current_desc"
      desc_shown=true
    else
      printf "    %s\n" "$domain"
    fi
  fi
done < "$ALLOWLIST"
echo ""

# echo "  MCP servers: "
# echo "Linear (read-only)"
# echo "Playwright"
# echo ""
