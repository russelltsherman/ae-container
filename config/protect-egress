#!/usr/bin/env bash
set -euo pipefail

# --- IPv4 rules ---
iptables -F OUTPUT
iptables -A OUTPUT -o lo -j ACCEPT

# --- IPv6 rules ---
ip6tables -F OUTPUT
ip6tables -A OUTPUT -o lo -j ACCEPT

# Allow direct traffic to the Docker host gateway (host.docker.internal).
# This lets the omlx aliases reach the local model server without going
# through squid, which Node.js HTTP clients don't reliably support for
# plain HTTP. Safe because the host is the user's own machine, not the
# public internet. The gateway may resolve to IPv4, IPv6, or both depending
# on the Docker Desktop version and host network configuration.
while IFS= read -r line; do
  addr="$(echo "$line" | awk '{print $1}')"
  [[ -z "$addr" ]] && continue
  if [[ "$addr" == *:* ]]; then
    ip6tables -A OUTPUT -d "$addr" -j ACCEPT
  else
    iptables -A OUTPUT -d "$addr" -j ACCEPT
  fi
done < <(getent hosts host.docker.internal 2>/dev/null || true)

# Allow the squid proxy user to reach the internet
iptables -A OUTPUT -m owner --uid-owner proxy -j ACCEPT
ip6tables -A OUTPUT -m owner --uid-owner proxy -j ACCEPT

# Drop all other outbound traffic
iptables -A OUTPUT -j DROP
ip6tables -A OUTPUT -j DROP
